# Project Nobi — Environment Variables
# Copy this to .env and fill in your values

# === LLM API (choose one or both) ===
# Chutes.ai — low cost (~$0.0001/query), get key from chutes.ai
CHUTES_API_KEY=
CHUTES_MODEL=deepseek-ai/DeepSeek-V3-0324
CHUTES_JUDGE_MODEL=deepseek-ai/DeepSeek-V3-0324

# OpenRouter — fallback judge, get key from openrouter.ai
OPENROUTER_API_KEY=

# === Bittensor ===
SUBTENSOR_NETWORK=test
NETUID=267
WALLET_NAME=my_wallet
WALLET_HOTKEY=nobi-miner
WALLET_PASSWORD=

# === Telegram Bot ===
# Get token from @BotFather on Telegram
NOBI_BOT_TOKEN=

# === Optional ===
LOG_LEVEL=INFO
