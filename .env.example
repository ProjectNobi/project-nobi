# Project Nobi — Environment Variables

# OpenRouter API key (required for miner inference and validator scoring)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Bittensor network (test or finney)
SUBTENSOR_NETWORK=test

# Subnet netuid
NETUID=1

# Wallet name and hotkey
WALLET_NAME=default
WALLET_HOTKEY=default
