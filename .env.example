# ── Nobi Rate Limits ──────────────────────────────────
# Adjust these to scale from testnet to mainnet
# Testnet defaults (generous for testing):
NOBI_MESSAGES_PER_DAY=300
NOBI_MESSAGES_PER_MINUTE=10
NOBI_VOICE_PER_DAY=30
NOBI_IMAGE_PER_DAY=30
NOBI_MEMORY_SLOTS=300
NOBI_MAX_RESPONSE_TOKENS=512

# Plus tier limits (env override)
NOBI_PLUS_MESSAGES_PER_DAY=900
NOBI_PLUS_MEMORY_SLOTS=900
NOBI_PLUS_VOICE_PER_DAY=90
NOBI_PLUS_IMAGE_PER_DAY=90
NOBI_PLUS_MAX_RESPONSE_TOKENS=1536

# Pro tier limits (env override)
NOBI_PRO_MESSAGES_PER_DAY=2700
NOBI_PRO_MEMORY_SLOTS=2700
NOBI_PRO_VOICE_PER_DAY=270
NOBI_PRO_IMAGE_PER_DAY=270
NOBI_PRO_MAX_RESPONSE_TOKENS=4608

# API rate limits (per IP, per minute)
NOBI_API_CHAT_RPM=30
NOBI_API_MEMORY_RPM=60
NOBI_API_GENERAL_RPM=120
NOBI_API_AUTH_RPM=10

# ── Mainnet recommended (conservative start) ─────────
# NOBI_MESSAGES_PER_DAY=100
# NOBI_MESSAGES_PER_MINUTE=5
# NOBI_VOICE_PER_DAY=10
# NOBI_IMAGE_PER_DAY=10
# NOBI_MEMORY_SLOTS=100
# NOBI_MAX_RESPONSE_TOKENS=384

# ── Mainnet growth (scale with emissions) ────────────
# NOBI_MESSAGES_PER_DAY=500
# NOBI_MESSAGES_PER_MINUTE=10
# NOBI_VOICE_PER_DAY=50
# NOBI_IMAGE_PER_DAY=50
# NOBI_MEMORY_SLOTS=1000
# NOBI_MAX_RESPONSE_TOKENS=512
