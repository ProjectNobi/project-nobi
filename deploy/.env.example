# Project Nobi — Environment Variables
# Copy to .env and fill in your values:
#   cp deploy/.env.example deploy/.env

# ─── AI API Keys ─────────────────────────────────────────────
# At least one LLM provider required
CHUTES_API_KEY=
CHUTES_MODEL=deepseek-ai/DeepSeek-V3.1-TEE
OPENROUTER_API_KEY=

# ─── Stripe Billing ─────────────────────────────────────────
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Database ────────────────────────────────────────────────
NOBI_DB_PATH=/data/memories.db
NOBI_BILLING_DB_PATH=/data/billing.db

# ─── API Server ──────────────────────────────────────────────
NOBI_API_PORT=8042

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.projectnobi.ai

# ─── Bittensor (miners/validators only) ─────────────────────
# WALLET_NAME=default
# HOTKEY_NAME=default
# NETUID=272
# SUBTENSOR_NETWORK=test
