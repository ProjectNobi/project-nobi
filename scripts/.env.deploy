# Deploy 256 — Configuration
# Edit this instead of touching deploy_256.py

# Wallet
WALLET_NAME=T68Coldkey
WALLET_PATH=/root/.bittensor/wallets
WALLET_PASSWORD_FILE=/root/.bittensor/.wallet_env

# Subnet
NETUID=272
NETWORK=test

# Neuron counts
MINER_COUNT=236
VAL_COUNT=20

# Registration timing (seconds between registrations)
REG_DELAY_SECONDS=14

# Chutes model auto-routing string
CHUTES_MODEL=deepseek-ai/DeepSeek-V3.1-TEE,deepseek-ai/DeepSeek-V3,openai/gpt-oss-120b-TEE,chutesai/Mistral-Small-3.2-24B-Instruct-2506:latency

# Port ranges
MINER_PORT_BASE=9000
VAL_PORT_BASE=8000
